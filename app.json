{
  "expo": {
    "scheme": "hairdresser",
    "name": "Gümüş Makas",
    "slug": "HairDresser",
    "version": "1.0.0",
    "orientation": "portrait",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "requireFullScreen": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "This app needs your location to show nearby barbershops and barbers.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "This app needs your location even when closed to keep free barbers' locations updated.",
        "NSLocationAlwaysUsageDescription": "This app needs your location even when closed to keep free barbers' locations updated.",
        "UIBackgroundModes": [
          "location",
          "fetch"
        ]
      },
      "bundleIdentifier": "com.hairdresser.app",
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "RECORD_AUDIO"
      ],
      "googleServicesFile": "./google-services.json",
      "package": "com.hairdresser.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./assets/icon.png",
          "resizeMode": "contain",
          "imageWidth": 320
        }
      ],
      "./plugins/withNotificationChannel",
      "./plugins/withPhoneOnly",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "This app needs your location even when closed to keep free barbers' locations updated.",
          "locationAlwaysPermission": "This app needs your location even when closed to keep free barbers' locations updated.",
          "locationWhenInUsePermission": "This app needs your location to show nearby barbershops and barbers."
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/messaging"
    ],
    "fonts": [
      "./assets/fonts/centurygothic.ttf",
      "./assets/fonts/centurygothic_bold.ttf"
    ]
  }
}