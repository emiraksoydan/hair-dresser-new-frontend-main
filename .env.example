# Kopyala: cp .env.example .env  —  .env gitignore'da (asla commit etme)
#
# EAS cloud (production): expo.dev → Project → Environment variables
# veya CLI: eas env:create ... --environment production
# eas.json → production profile'da "environment": "production" olmalı (yüklü).
# Lokal: eas env:pull --environment production

# Google Maps (Android manifest + runtime)
GOOGLE_MAPS_API_KEY=

# Firebase — dosya yolu (repo kökünde google-services.json / GoogleService-Info.plist tutuyorsanız)
GOOGLE_SERVICES_JSON=./google-services.json
GOOGLE_SERVICES_PLIST=./GoogleService-Info.plist

# Native izin metinleri dili (tr|en|de|ar); yeni build gerekir
EXPO_NATIVE_PERM_LANG=tr
